g setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  20 |     const usuario = obtenerUsuarioGuardado();\n  21 |     if (usuario) {\n> 22 |       setUsuarioActual(usuario);\n     |       ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  23 |     }\n  24 |     setSesionHidratada(true);\n  25 |   }, []);","line":22,"column":7,"nodeType":null,"endLine":22,"endColumn":23}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\n\nconst obtenerUsuarioGuardado = () => {\n  const raw = localStorage.getItem('usuario') || localStorage.getItem('user');\n  if (!raw) return null;\n\n  try {\n    const user = JSON.parse(raw);\n    return user?.rol ? user : null;\n  } catch {\n    return null;\n  }\n};\n\nexport function useAuth(navigate, location, rutaPanelPorRol, esRutaInterna) {\n  const [sesionHidratada, setSesionHidratada] = useState(false);\n  const [usuarioActual, setUsuarioActual] = useState(null);\n\n  useEffect(() => {\n    const usuario = obtenerUsuarioGuardado();\n    if (usuario) {\n      setUsuarioActual(usuario);\n    }\n    setSesionHidratada(true);\n  }, []);\n\n  const limpiarSesionLocal = useCallback(() => {\n    localStorage.removeItem('token');\n    localStorage.removeItem('usuario');\n    localStorage.removeItem('user');\n  }, []);\n\n  const cerrarSesion = useCallback((onSesionCerrada) => {\n    setUsuarioActual(null);\n    limpiarSesionLocal();\n    if (onSesionCerrada) onSesionCerrada();\n    navigate('/', { replace: true });\n  }, [limpiarSesionLocal, navigate]);\n\n  const cambiarUsuario = useCallback((onSesionCerrada) => {\n    const from = location.pathname.startsWith('/panel') ? location.pathname : '/panel';\n    setUsuarioActual(null);\n    limpiarSesionLocal();\n    if (onSesionCerrada) onSesionCerrada();\n    navigate('/login', { state: { from }, replace: true });\n  }, [limpiarSesionLocal, location.pathname, navigate]);\n\n  const handleLoginUnificado = useCallback((usuario) => {\n    const from = location.state?.from;\n    const rutaRol = rutaPanelPorRol(usuario?.rol) || '/panel';\n    const destino = esRutaInterna(from) ? from : rutaRol;\n\n    setUsuarioActual(usuario);\n    localStorage.setItem('usuario', JSON.stringify(usuario));\n    localStorage.setItem('user', JSON.stringify(usuario));\n    navigate(destino, { replace: true });\n  }, [location.state, navigate, rutaPanelPorRol, esRutaInterna]);\n\n  return {\n    sesionHidratada,\n    usuarioActual,\n    cerrarSesion,\n    cambiarUsuario,\n    handleLoginUnificado,\n  };\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\daesloard\\Downloads\\sistema_tramites\\frontend\\src\\hooks\\useNotificaciones.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\daesloard\\Downloads\\sistema_tramites\\frontend\\src\\main.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\daesloard\\Downloads\\sistema_tramites\\frontend\\src\\services\\api.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\daesloard\\Downloads\\sistema_tramites\\frontend\\src\\styles\\components\\AppStyles.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\daesloard\\Downloads\\sistema_tramites\\frontend\\src\\styles\\components\\AvisoModalStyles.js","messages":[],"